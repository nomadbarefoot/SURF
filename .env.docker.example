# Docker runtime configuration for SURF.
# Copy this file to .env.docker, fill in your values, then run:
#   docker compose --env-file .env.docker up --build

SURF_API_TOKEN=
SEARXNG_SECRET=
SURF_LOG_LEVEL=INFO
SURF_EXA_API_KEY=
# Scoped LiteLLM key authorized for the embed-text alias.
SURF_EMBEDDING_API_KEY=
SURF_EMBEDDING_MODEL=embed-text
SURF_EMBEDDING_DIMENSIONS=768
